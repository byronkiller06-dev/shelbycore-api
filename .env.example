# ═══════════════════════════════════════════════════════════════
#  ShelbyCore AI · ORION — Variables de entorno
#  Dev: copia como .env | Prod: configura en Railway dashboard
# ═══════════════════════════════════════════════════════════════

# Base de datos (Railway PostgreSQL en producción, Docker local en dev)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"

# JWT
JWT_SECRET="genera-un-secreto-largo-y-aleatorio-aqui"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=4000

# CORS — vacío permite todo (JWT protege los endpoints)
CORS_ORIGIN=""

# Google OAuth (Web Application client en Google Cloud Console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# PRODUCCIÓN: https://TU-PROYECTO.up.railway.app/api/auth/google/callback
# DESARROLLO:  http://localhost:4000/api/auth/google/callback
GOOGLE_CALLBACK_URL=""

# URL a la que el backend redirige tras OAuth
# APK Capacitor: siempre http://localhost (WebView de Capacitor intercepta esta URL)
# Web browser:   http://localhost:3000
FRONTEND_URL="http://localhost"

# APIs externas (opcionales)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GOOGLE_PLACES_API_KEY=""
